APP_PORT=3010

### Remnawave Panel URL, can be http://remnawave:3000 or https://panel.example.com
REMNAWAVE_PANEL_URL=https://remnawave:3000
### Replace with own API Token. Create in Remnawave Dashboard → Remnawave Settings → API Tokens section 
REMNAWAVE_API_TOKEN=

# Serve at custom root path, for example, this value can be: CUSTOM_SUB_PREFIX=sub
# Do not place / at the start/end
CUSTOM_SUB_PREFIX=

# If you use "Caddy with security" addon or "Tiny Auth", you can place here X-Api-Key, which will be applied to requests to Remnawave Panel.
# Will be used with "X-Api-Key" header
CADDY_AUTH_API_TOKEN=

# If you use Cloudflare Zero Trust
CLOUDFLARE_ZERO_TRUST_CLIENT_ID=""
CLOUDFLARE_ZERO_TRUST_CLIENT_SECRET=""

# Support Marzban links    
MARZBAN_LEGACY_LINK_ENABLED=false
MARZBAN_LEGACY_SECRET_KEY=

# Don't use this unless you know what you are doing!
# Example format: "2025-01-17T15:38:45.065Z"
MARZBAN_LEGACY_SUBSCRIPTION_VALID_FROM=

# Merge linked subscriptions into Mihomo/Clash (YAML) configs
MERGE_MIHOMO=false

# Also inject merged proxy names into proxy-groups (requires MERGE_MIHOMO=true)
MERGE_MIHOMO_PROXY_GROUPS=false

# Merge linked subscriptions for base64-encoded proxy lists
MERGE_BASE64=false

# Merge full host configs from linked subscriptions into Xray JSON array
MERGE_XRAY_HOSTS=false

# Inject outbounds from linked subscriptions into each Xray JSON config
MERGE_XRAY_OUTBOUNDS=false

# Override Reality fingerprint in Xray outbounds and vless:// links based on client OS
# (detected via x-device-os header or User-Agent)
OVERRIDE_FINGERPRINT_PER_OS=false

# Where to insert merged linked hosts into the array: start, upper_middle, middle or end
MERGE_HOSTS_POSITION=end

# Append the formatted traffic-left header value to merged (linked) host remarks
APPEND_TRAFFIC_LEFT=false